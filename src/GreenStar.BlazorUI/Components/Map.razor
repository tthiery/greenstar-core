@using GreenStar.AppService
@using GreenStar.Renderer
@using GreenStar.Stellar
@using GreenStar.Traits
@using SkiaSharp
@using SkiaSharp.Views.Blazor
@inject IJSRuntime jsRuntime;
@inject MapService _mapService;
@inject ITurnService _turnService;
@inject ICommandService _commandService

<script>
    window.mapUtils = {
        addDefaultPreventingHandler: function () {
            let element = document.getElementById("map");
            element.addEventListener("wheel", e => e.preventDefault(), { passive: false });
        }
    }
</script>

<div id="map" style="position:relative;top:0;left:0;height:100%;width:100%;"
     @onclick="OnClick"
     @onpointerdown="OnPointer"
     @onpointerup="OnPointer"
     @onpointermove="OnPointer"
     @onpointerleave="OnPointer"
     @onwheel="OnWheelAsync">
    <SKGLView @ref="x"
              OnPaintSurface="OnPaintSurface"
              IgnorePixelScaling="true"
              style="position:relative;width:100%;height:100%">
    </SKGLView>
</div>
