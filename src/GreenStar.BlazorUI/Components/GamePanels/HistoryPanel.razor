@if (Information is not null)
{
    <FluentStack Orientation="Orientation.Vertical">
        @foreach (var msg in Information.NewMessages)
        {
            <FluentCard Style="--elevation-shadow-card-rest: 0 0 1px rgba(0, 0, 0, 0.05)">
                <FluentLabel>
                    @msg.Text<br />
                    @msg.MessageType
                </FluentLabel>
            </FluentCard>
        }
    </FluentStack>
}